# ---------------------------------------------------------------------------
# Vercel — the Next.js WEB APP. Paste these into Vercel → Project → Settings →
# Environment Variables (Production). Same Neon database as the Railway worker.
# ---------------------------------------------------------------------------

# Neon Postgres connection — use the POOLED connection string (host contains
# "-pooler"), which is right for serverless. Must include ?sslmode=require.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.ap-southeast-2.aws.neon.tech/roster?sslmode=require

# Secret that signs owner sign-in sessions. Generate once with: npx auth secret
# Use the SAME value here and on the worker.
AUTH_SECRET=replace-with-a-long-random-string

# Canonical site URL Auth.js uses to build owner magic-link sign-in URLs.
AUTH_URL=https://roster.zaleit.com.au

# Public base URL used to build staff magic links and the shareable roster link.
APP_URL=https://roster.zaleit.com.au

# Send real email via Resend (not the local SMTP catcher).
EMAIL_TRANSPORT=resend

# Verified sender on your Resend domain (zaleit.com.au).
EMAIL_FROM=Roster <roster@zaleit.com.au>

# Resend API key with sending access.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Production mode (Vercel usually sets this automatically; included for clarity).
NODE_ENV=production
