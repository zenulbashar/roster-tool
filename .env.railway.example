# ---------------------------------------------------------------------------
# Railway — the BACKGROUND WORKER (scripts/worker.ts). Paste these into
# Railway → Service → Variables. Same Neon database as the Vercel web app.
# ---------------------------------------------------------------------------

# Neon Postgres connection — use the DIRECT (non-pooled) connection string
# (host has NO "-pooler"). pg-boss needs a session-mode connection for its
# locking/maintenance. Must include ?sslmode=require.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.ap-southeast-2.aws.neon.tech/roster?sslmode=require

# Must be the SAME value as on Vercel. Required because env validation checks it
# at startup (the worker itself doesn't use auth).
AUTH_SECRET=replace-with-a-long-random-string

# Public base URL — the worker builds links inside reminder and published-roster
# emails, so this must be the production URL (not localhost).
APP_URL=https://roster.zaleit.com.au

# Send real email via Resend.
EMAIL_TRANSPORT=resend

# Verified sender on your Resend domain (zaleit.com.au).
EMAIL_FROM=Roster <roster@zaleit.com.au>

# Resend API key with sending access.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Production mode (JSON logs; skips the dev-only pretty logger).
NODE_ENV=production
