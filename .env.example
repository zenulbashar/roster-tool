# ---------------------------------------------------------------------------
# Roster tool environment configuration.
# Copy this file to `.env` and adjust as needed:  cp .env.example .env
# Every variable the app reads is documented here. Never commit your real .env.
# ---------------------------------------------------------------------------

# Node environment: development | test | production
NODE_ENV=development

# --- Database -------------------------------------------------------------
# Postgres connection string. The default matches docker-compose.yml.
DATABASE_URL=postgresql://roster:roster@localhost:5432/roster

# --- Auth.js (owner sign-in) ----------------------------------------------
# Secret used to sign session tokens. Generate one with: npx auth secret
AUTH_SECRET=replace-me-with-a-long-random-string
# Canonical URL of the app for Auth.js (usually same as APP_URL in dev).
AUTH_URL=http://localhost:3000

# --- App ------------------------------------------------------------------
# Public base URL used to build magic links inside emails.
APP_URL=http://localhost:3000

# --- Email ----------------------------------------------------------------
# Delivery mechanism:
#   smtp   -> local SMTP catcher (Mailpit) — recommended for local dev
#   resend -> Resend HTTP API — used in production
EMAIL_TRANSPORT=smtp

# From address shown on all outgoing email.
EMAIL_FROM=Roster <roster@example.com>

# SMTP settings (only used when EMAIL_TRANSPORT=smtp). Defaults match Mailpit
# in docker-compose.yml. View caught emails at http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025

# Resend API key (only used when EMAIL_TRANSPORT=resend). Get one at resend.com
RESEND_API_KEY=

# --- Cloudflare Turnstile (public form bot protection) --------------------
# Required before publishing any form in production; the public form-fill route
# verifies the token server-side and FAILS CLOSED in production if the secret is
# unset. For local dev use Cloudflare's always-pass test keys below.
#   Test site key:   1x00000000000000000000AA
#   Test secret key: 1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# --- Inbound SSO from prompt2eat ------------------------------------------
# The Ed25519 PUBLIC key that verifies prompt2eat handoff tokens at
# POST /api/sso/prompt2eat (a public PEM or its base64). OPTIONAL — the verify
# path fails closed (rejects every handoff) when unset. prompt2eat holds the
# matching PRIVATE key; Roster can verify a token but never mint one. Generate:
#   openssl genpkey -algorithm ed25519 -out roster-sso-priv.pem   (-> prompt2eat)
#   openssl pkey -in roster-sso-priv.pem -pubout -out roster-sso-pub.pem  (-> here)
# PROMPT2EAT_SSO_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# --- Google Drive document storage ----------------------------------------
# Lets owners connect their OWN Google Drive (drive.file scope only) to store
# staff documents. This is an ADDITIONAL authorization, NOT a sign-in method.
# All four are optional for boot; the connect flow FAILS CLOSED (refuses to
# start) until they're all set, so a token is never stored without encryption.
#
# Create an OAuth 2.0 Client (type: Web application) in Google Cloud Console
# with the Drive API enabled. Add the redirect URI below as an authorized
# redirect URI. Google may require app verification before non-test users can
# connect.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must EXACTLY match an authorized redirect URI in the Google Cloud console.
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback
# Base64 of 32 random bytes — AES-256-GCM key encrypting stored OAuth tokens.
# Shared by BOTH the Google Drive and Xero integrations. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=

# --- Xero Payroll AU integration ------------------------------------------
# Lets owners connect their Xero org and push APPROVED hours as DRAFT timesheets
# (a human approves + runs pay in Xero — the app has NO pay-run capability).
# Additional authorization, NOT a sign-in method. All three are optional for
# boot; the connect flow FAILS CLOSED until they + TOKEN_ENCRYPTION_KEY are set.
# Create an OAuth 2.0 app at developer.xero.com with the redirect URI below and
# read/timesheet scopes (payroll.timesheets, payroll.employees.read,
# payroll.settings.read) — NEVER payroll.payruns.
# NOTE: the AU-2.0 timesheet base path + scope are isolated in
# src/lib/xero/tokens.ts and verified at the first live AU connect (README).
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
# Must EXACTLY match a redirect URI on the Xero app.
XERO_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/xero/callback

# --- Zale IT admin console (M37) ------------------------------------------
# Comma/whitespace-separated emails that may bootstrap into /admin. On first
# magic-link sign-in a matching email is provisioned a platform_admin row (a
# ROLE grant on top of the normal owner login — NOT a separate login). Optional
# and FAIL CLOSED: unset means no NEW admin can bootstrap (existing admins keep
# working). Admins are Zale IT staff, unrelated to any tenant.
# ADMIN_ALLOWLIST=priya@zaleit.com.au, ops@zaleit.com.au

# --- Logging --------------------------------------------------------------
# Optional. One of: trace | debug | info | warn | error
# LOG_LEVEL=debug
